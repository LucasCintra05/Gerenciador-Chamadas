<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=], initial-scale=1.0">
    <title>Lista Chamadas</title>
    <style>
        body{ font-family: Arial, Helvetica, sans-serif; padding: 20px;}
        table{border-collapse: collapse; width: 100%;}
        th,td{border: 1px solid #ddd; padding: 8px;}
        th{background-color: #222;color: white;}
        form{margin-bottom: 20px;}
        input{margin-right: 10px; padding: 5px;}
        button{padding: 5px 10px;}
        .deletar_btn{background-color: red; color: white; border: white solid; border-radius: 5px;}
        .status_btn{background-color: rgba(255, 255, 0, 0.772); color: black; border: white solid; border-radius: 5px;}
        .editar_btn{background-color: rgba(3, 149, 165, 0.772); color: white; border: white solid; border-radius: 5px;}
        #td_button{display: grid; grid-auto-flow: column; gap: 5px}
    </style>
</head>
    <body>
        <h1>Produtos Cadastrados</h1>
        <form action="" id="form_chamados">
            <input type="text" name="" id="titulo" placeholder="Titulo da Chamada" required>
            <input type="text" name="" id="descricao" placeholder="Descrição da Chamada" required>
            <input type="text" name="" id="prioridade" placeholder="Prioridade da Chamada" required>
            <button type="submit" onclick="">Cadastrar</button>
        </form>
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Título</th>
                    <th>Descrição</th>
                    <th>Prioridade</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody id="copor_tabela">
                <% chamados.forEach(chamados =>{%>
                <tr>
                    <td id="td_id"><%= chamados.id %></td>
                    <td><%= chamados.titulo %></td>
                    <td><%= chamados.descricao %></td>
                    <td><%= chamados.prioridade %></td>
                    <td><%= chamados.status %></td>
                    <td id="td_button">
                        <button class="deletar_btn" onclick="remover(<%= chamados.id %>)">X</button>
                        <button class="status_btn" onclick="atualizar_status(<%= chamados.id %>)">Status</button>
                        <button class="editar_btn" onclick="editar_chamados(<%= chamados.id %>)">Editar</button>
                    </td>
                    
                </tr>
                <% }) %>
            </tbody>
        </table>
        <script> //quem executa esse script é a maquina cliente - a comunicação que fazemos aqui é com a API
            const form = document.getElementById('form_chamados')

            async function editar_chamados(id) {
                const titulo = document.getElementById('titulo').value
                const descricao = document.getElementById('descricao').value
                const prioridade = document.getElementById('prioridade').value.toUpperCase()

                const res = await fetch(`chamados/${id}`, {
                    method: 'PUT',
                    headers:{'Content-Type': 'application/json'},
                    body: JSON.stringify({titulo, descricao, prioridade})

                })

                if(res.ok){
                    alert('Chamado editado com sucesso.')
                    window.location.reload()
                }else{
                    alert('Erro ao editar chamado.')
                }

            }

            async function atualizar_status(id) {
                const res = await fetch(`/chamados/${id}/status`, {
                    method: 'PATCH',
                    
                })

                if(res.ok){
                    alert('Status atualizado com sucesso.')
                    window.location.reload()
                }else{
                    alert('Erro ao atualizar chamado.')
                }
                
            }

            async function remover(id){
                if(!confirm('Deseja realmente deletar este chamado?'))return

                const res = await fetch(`/chamados/${id}`, {
                    method: 'DELETE',

                })
                if(res.ok){
                    alert('Chamado deletado com sucesso.')
                    window.location.reload()
                }else{
                    alert('Erro ao deletar chamado.')
                }
            }
            
            
            form.addEventListener('submit', async(e)=>{
                e.preventDefault()
                const titulo = document.getElementById('titulo').value
                const descricao = document.getElementById('descricao').value
                const prioridade = document.getElementById('prioridade').value.toUpperCase()

                const res = await fetch('/chamados', { //temos q configurar a chamada que fazermos a API
                    method: 'POST',
                    headers:{'Content-Type': 'application/json'},
                    body: JSON.stringify({titulo, descricao, prioridade})
                })

                if(res.ok){
                    alert('Chamado cadastrado com sucesso.')
                    window.location.reload()
                }else{
                    alert('Erro ao cadastrar chamado.')
                }

            })
        </script>
    </body>
</html>